// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. USER & AUTHENTICATION
// ==========================================

enum Role {
  USER
  ADMIN
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  mobile          String?   // Dari SQL lama: mobile
  password        String
  role            Role      @default(USER)
  emailVerifiedAt DateTime? @map("email_verified_at")
  profileImage    String?   // Dari SQL lama: image
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relasi
  addresses     Address[]
  orders        Order[]
  transactions  Transaction[]
  wishlist      Wishlist[]

  @@map("users")
}

model Address {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  
  // Field Alamat Lengkap (Sesuai SQL lama)
  name        String
  phone       String
  locality    String
  address     String   @db.Text
  city        String
  state       String
  country     String
  landmark    String?
  zip         String?
  
  type        String   @default("home") // home/office
  isDefault   Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ==========================================
// 2. PRODUCT CATALOG (E-Commerce Core)
// ==========================================

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  image     String?
  products  Product[]

  @@map("brands")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  image     String?
  parentId  String?   @map("parent_id") // Support sub-category
  
  products          Product[]
  featuredInConfig  FeaturedCategory[] // Relasi ke CMS

  @@map("categories")
}

model Product {
  id             String   @id @default(cuid())
  
  // Field Penting
  name           String
  slug           String   @unique
  shortDesc      String?  @map("short_description") @db.Text
  description    String?  @db.LongText
  
  // Harga (Decimal biar presisi duit)
  regularPrice   Decimal  @map("regular_price") @db.Decimal(12, 2)
  salePrice      Decimal? @map("sale_price") @db.Decimal(12, 2)
  
  // Inventory
  SKU            String?
  stockStatus    String   @default("instock") @map("stock_status")
  quantity       Int      @default(10)
  
  // Media & Metadata
  featured       Boolean  @default(false)
  image          String?  // Gambar utama (thumbnail)
  images         String?  @db.Text // Gambar gallery (bisa JSON string atau dipisah koma)
  
  // Relasi FK
  brandId        String?  @map("brand_id")
  categoryId     String?  @map("category_id")
  brand          Brand?    @relation(fields: [brandId], references: [id])
  category       Category? @relation(fields: [categoryId], references: [id])
  
  // Relasi Lain
  orderItems     OrderItem[]
  wishlist       Wishlist[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("products")
}

// ==========================================
// 3. ORDER & TRANSACTION SYSTEM
// ==========================================

enum OrderStatus {
  ordered
  delivered
  canceled
}

model Order {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  
  // Rekap Duit
  subtotal      Decimal     @db.Decimal(12, 2)
  discount      Decimal     @default(0) @db.Decimal(12, 2)
  tax           Decimal     @default(0) @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  
  // Snapshot Alamat Pengiriman (Penting!)
  name          String      
  phone         String
  locality      String
  address       String      @db.Text
  city          String
  state         String
  country       String
  landmark      String?
  zip           String?

  // Status & Tanggal
  status        OrderStatus @default(ordered)
  isShippingDifferent Boolean @default(false) @map("is_shipping_different")
  deliveredDate DateTime?   @map("delivered_date")
  canceledDate  DateTime?   @map("canceled_date")
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  transaction   Transaction?

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  
  price     Decimal @db.Decimal(12, 2) // Harga saat dibeli
  quantity  Int
  
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  orderId       String   @unique @map("order_id")
  
  mode          String   // cod, card, paypal, midtrans
  status        String   // pending, approved, declined
  
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Wishlist {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  productId String @map("product_id")

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // Mencegah duplikat
  @@map("wishlists")
}

// ==========================================
// 4. CMS (LANDING PAGE & CONFIG) 🚀
// ==========================================

// Slider Utama (Hero Section)
model HeroSlide {
  id          String   @id @default(cuid())
  tagline     String?  // "New Collection"
  title       String   // "Nike Air Jordan"
  subtitle    String?  // "Diskon 50% Hari Ini"
  image       String   // URL Gambar
  ctaText     String   @default("Shop Now")
  ctaLink     String   @default("/shop")
  order       Int      @default(0) // Buat ngatur urutan slide
  isActive    Boolean  @default(true)
  
  @@map("cms_hero_slides")
}

// Banner Promo (Grid Banners)
model PromoBanner {
  id          String   @id @default(cuid())
  title       String?  // "Men's Collection"
  subtitle    String?  // "Spring 2024"
  image       String
  link        String   // Klik lari kemana
  position    String   // "top-left", "bottom-wide" (Buat layout grid)
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  @@map("cms_promo_banners")
}

// Featured Categories (Lingkaran Kategori di Home)
model FeaturedCategory {
  id          String   @id @default(cuid())
  categoryId  String
  customName  String?  // Kalau mau ganti nama label (opsional)
  image       String?  // Kalau mau gambar beda dr kategori asli (opsional)
  order       Int      @default(0)
  
  category    Category @relation(fields: [categoryId], references: [id])

  @@map("cms_featured_categories")
}

// Pengaturan Global Website
model SiteConfig {
  id              String  @id @default("config_main")
  siteName        String  @default("MoneyLabs")
  logoUrl         String?
  announcementBar String? // Teks jalan di atas
  
  // Kontak Info
  whatsapp        String? 
  instagram       String?
  email           String?
  address         String? @db.Text

  updatedAt       DateTime @updatedAt
  
  @@map("cms_site_config")
}