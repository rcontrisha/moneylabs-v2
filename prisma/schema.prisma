// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. USER & AUTHENTICATION
// ==========================================

enum Role {
  USER
  ADMIN
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  mobile          String?   
  password        String
  role            Role      @default(USER)
  emailVerifiedAt DateTime? @map("email_verified_at")
  profileImage    String?   
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  addresses     Address[]
  orders        Order[]
  transactions  Transaction[]
  wishlist      Wishlist[]

  @@map("users")
}

model Address {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  phone       String
  locality    String
  address     String   @db.Text
  city        String
  state       String
  country     String
  landmark    String?
  zip         String?
  type        String   @default("home") 
  isDefault   Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ==========================================
// 2. PRODUCT CATALOG
// ==========================================

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  image     String?
  products  Product[]

  @@map("brands")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  image     String?
  parentId  String?   @map("parent_id") 
  
  products          Product[]
  featuredInConfig  FeaturedCategory[] 

  @@map("categories")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  shortDesc      String?  @map("short_description") @db.Text
  description    String?  @db.LongText
  
  // 🚀 REFACTOR: Harga sekarang dinamis di dalam JSON 'sizes'
  // Format JSON: { "new": [{size, regularPrice, salePrice, stock}], "used": [{size, regularPrice, salePrice, stock, condition, defects, images}] }
  sizes          Json?    @map("sizes")
  
  SKU            String?
  stockStatus    String   @default("instock") @map("stock_status")
  quantity       Int      @default(0) // Total stok gabungan
  
  featured       Boolean  @default(false)
  image          String?
  images         String?  @db.Text 
  
  brandId        String?  @map("brand_id")
  categoryId     String?  @map("category_id")
  brand          Brand?   @relation(fields: [brandId], references: [id])
  category       Category? @relation(fields: [categoryId], references: [id])
  
  orderItems     OrderItem[]
  wishlist       Wishlist[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("products")
}

// ==========================================
// 3. ORDER & TRANSACTION SYSTEM
// ==========================================

enum OrderStatus {
  ordered
  delivered
  canceled
}

model Order {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  subtotal      Decimal     @db.Decimal(12, 2)
  discount      Decimal     @default(0) @db.Decimal(12, 2)
  tax           Decimal     @default(0) @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  
  name          String      
  phone         String
  locality      String
  address       String      @db.Text
  city          String
  state         String
  country       String
  landmark      String?
  zip           String?

  status        OrderStatus @default(ordered)
  isShippingDifferent Boolean @default(false) @map("is_shipping_different")
  deliveredDate DateTime?   @map("delivered_date")
  canceledDate  DateTime?   @map("canceled_date")
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  transaction   Transaction?

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  
  price     Decimal @db.Decimal(12, 2) 
  quantity  Int
  
  // 🚀 REFACTOR: Snapshot variant yang dibeli
  selectedSize String? @map("selected_size")
  condition    String? // "new" atau "used"

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  orderId       String   @unique @map("order_id")
  mode          String   
  status        String   
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Wishlist {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  productId String @map("product_id")

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

// ==========================================
// 4. CMS (LANDING PAGE & CONFIG)
// ==========================================

model HeroSlide {
  id          String   @id @default(cuid())
  tagline     String?  
  title       String   
  subtitle    String?
  image       String   
  ctaText     String   @default("Shop Now")
  ctaLink     String   @default("/shop")
  order       Int      @default(0) 
  isActive    Boolean  @default(true)
  
  @@map("cms_hero_slides")
}

model PromoBanner {
  id          String   @id @default(cuid())
  title       String?  
  subtitle    String?  
  image       String
  link        String   
  position    String   
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  @@map("cms_promo_banners")
}

model FeaturedCategory {
  id          String   @id @default(cuid())
  categoryId  String
  customName  String?  
  image       String?  
  order       Int      @default(0)
  
  category    Category @relation(fields: [categoryId], references: [id])

  @@map("cms_featured_categories")
}

model SiteConfig {
  id              String  @id @default("config_main")
  siteName        String  @default("MoneyLabs")
  logoUrl         String?
  announcementBar String? 
  whatsapp        String?
  instagram       String?
  email           String?
  address         String? @db.Text

  updatedAt       DateTime @updatedAt
  
  @@map("cms_site_config")
}